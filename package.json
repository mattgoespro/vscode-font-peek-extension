{
  "name": "vscode-font-glyph-preview-extension",
  "displayName": "font-glyph-preview",
  "description": "Preview font glyphs in files from within Visual Studio Code",
  "version": "0.0.1",
  "icon": "assets/logo.png",
  "main": "./dist/extension.js",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.51.0"
  },
  "scripts": {
    "dev": "webpack --config webpack.config.ts --mode development --watch",
    "build": "webpack --config webpack.config.ts --mode production",
    "vscode:prepublish": "npm run build",
    "lint": "eslint src",
    "lint:scss": "stylelint src/**/*.scss"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "fontGlyphPreview.editor.preview",
        "displayName": "Font Glyph Preview",
        "selector": [
          {
            "filenamePattern": "*.ttf"
          },
          {
            "filenamePattern": "*.otf"
          },
          {
            "filenamePattern": "*.woff"
          },
          {
            "filenamePattern": "*.woff2"
          },
          {
            "filenamePattern": "*.eot"
          }
        ]
      }
    ],
    "configuration": [
      {
        "properties": {
          "preview-page-size": {
            "type": "number",
            "description": "The number of glyphs to display per page in the preview",
            "default": 10,
            "minimum": 20,
            "maximum": 500,
            "scope": "resource"
          }
        }
      }
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.5",
    "@mui/material": "^6.4.5",
    "fontkit": "^2.0.4",
    "material-react-table": "^3.2.0",
    "pako": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@html-eslint/eslint-plugin": "^0.35.0",
    "@html-eslint/parser": "^0.35.0",
    "@types/fontkit": "^2.0.7",
    "@types/node": "^22.13.5",
    "@types/pako": "^2.0.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.97.0",
    "@types/webpack": "^5.28.5",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-import-resolver-webpack": "^0.13.10",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "html-loader": "^5.1.0",
    "mini-css-extract-plugin": "^2.9.2",
    "path-browserify": "^1.0.1",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^10.1.4",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.2",
    "sass": "^1.85.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "stylelint": "^16.14.1",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "terser-webpack-plugin": "^5.3.11",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  }
}
